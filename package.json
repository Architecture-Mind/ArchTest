{
  "name": "@kidkender/archtest",
  "version": "0.1.0",
  "description": "Code-first API contract testing — auto-discover routes, generate test cases, detect breaking changes. No server required.",
  "type": "module",
  "bin": {
    "archtest": "./dist/index.cjs"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "tsc --noEmit --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "prepublishOnly": "node build.mjs"
  },
  "files": [
    "dist/index.cjs"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "nestjs",
    "api-testing",
    "contract-testing",
    "static-analysis",
    "test-generation",
    "snapshot",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kidkender/archtest"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@kidkender/archmind": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "@kidkender/archmind": {
      "optional": false
    }
  }
}
