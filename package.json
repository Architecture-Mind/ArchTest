{
  "name": "@kidkender/archtest",
  "version": "0.2.0",
  "description": "Code-first API contract intelligence — analyze, snapshot, generate, verify, lint, and fuzz your API from source code. No Swagger required.",
  "type": "module",
  "bin": {
    "archtest": "./dist/index.cjs"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "tsc --noEmit --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "prepublishOnly": "node build.mjs"
  },
  "files": [
    "dist/index.cjs"
  ],
  "dependencies": {
    "@kidkender/archmind": "^0.3.0",
    "@kidkender/archmind-laravel-parser": "^0.2.0",
    "@kidkender/archmind-nestjs-parser": "^0.3.0",
    "@kidkender/archmind-protocol": "^0.2.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "nestjs",
    "laravel",
    "api-testing",
    "contract-testing",
    "static-analysis",
    "test-generation",
    "snapshot",
    "fuzzing",
    "linter",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Architecture-Mind/ArchTest"
  },
  "engines": {
    "node": ">=18"
  }
}
